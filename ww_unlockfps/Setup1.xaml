<Window x:Class="ww_unlockfps.Setup1"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ww_unlockfps"
        mc:Ignorable="d"
        Title="Setup" Height="350" Width="450" ResizeMode="NoResize">
    <DockPanel Background="{DynamicResource GradientBackground}" LastChildFill="False">
        <Grid x:Name="DropArea" Width="400" Height="150" VerticalAlignment="Top" Margin="0,15,0,0" DockPanel.Dock="Top">
            <Rectangle RadiusX="5" RadiusY="5" Fill="Beige" Stroke="DarkBlue" StrokeDashArray="10,3" StrokeThickness="1" Height="150"/>
            <Label Content="Drag Game EXE file here" HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Meiryo" FontSize="16" Foreground="Gray"/>
        </Grid>
        <!-- 使用 Grid 布局替代原来的 DockPanel 布局 -->
        <Grid  Margin="16.5,11,0,0"  >
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>


            <!-- 在第2行第1列添加Label -->
            <Label Content="Game Path :" Grid.Row="0" Grid.Column="0" Padding="0,5,5,5"  />

            <!-- 在第2行第1列添加Label -->
            <Label Content="Game Server :" Grid.Row="2" Grid.Column="0" Padding="0,5,5,5" Margin="0,9,0,0" />

            <!-- 在第2行第1列添加Label -->
            <Label Content="Launch EXE :" Grid.Row="2" Grid.Column="1" Padding="0,5,5,5" Margin="0,9,55,0" HorizontalAlignment="Right" />


            <ComboBox x:Name="GAME_EXE_SELECT"  Width="130" Grid.Row="2" Grid.Column="1" Height="25" Margin="0,9,0,0" HorizontalAlignment="Right" VerticalContentAlignment="Center" SelectedIndex="0" Grid.ColumnSpan="2">
                <ComboBoxItem Content="Wuthering Waves.exe" />
                <ComboBoxItem Content="Client-Win64-Shipping.exe" />
            </ComboBox>

            <!-- Path_EXE 替换为Grid布局中的第1行第1列 -->
            <TextBox x:Name="Path_EXE" TextWrapping="NoWrap" Text="EXE_Path"  Grid.Row="0" Grid.Column="0" Height="25" VerticalContentAlignment="Center" IsReadOnly="True" Margin="0,0,75,0" Grid.ColumnSpan="3" Width="250" HorizontalAlignment="Right" />


            <!-- But_Confirm 替换为Grid布局中的第1行第2列 -->
            <Button x:Name="But_Browse"  Content="Browse" Grid.Row="0" Grid.Column="3" Width="65" Height="25"   VerticalAlignment="Center" Margin="9,0,0,0" HorizontalAlignment="Right" Click="Button_SELECT" />

            <!-- But_Clear 替换为Grid布局中的第1行第3列 -->
            <Button x:Name="But_Confirm" Click="Button_Confirm" Content="OK" Grid.Row="3" Grid.Column="2" Width="65" Height="25"  VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,9,0,0" />

            <!-- But_Clear 替换为Grid布局中的第1行第3列 -->
            <Button x:Name="But_Clear" Content="test btn" Grid.Row="3" Grid.Column="1" Width="65" Height="25"  Click="Button_Clear" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,9,75,0" Grid.ColumnSpan="2"/>

            <ComboBox x:Name="GAME_SERV"  Width="100" Grid.Row="2" Grid.Column="0" Height="25" Margin="85,9,0,0" HorizontalAlignment="Left" VerticalContentAlignment="Center" >
                <ComboBoxItem Content="CN (Obsoleted)" />
                <ComboBoxItem Content="Global (Obsoleted)" />
                <ComboBoxItem Content="Auto Detect (Obsoleted)" />
            </ComboBox>

            <!-- 在第2行第1列添加Label -->
            <Label Content="Custom Launch Param :" Grid.Row="1" Grid.Column="0" Padding="0,5,5,5" Margin="0,9,0,0" />

            <!-- Path_EXE 替换为Grid布局中的第1行第1列 -->
            <!--TextBox x:Name="Param_EXE" TextWrapping="NoWrap" Text="-RTX"  Grid.Row="1" Grid.Column="0" Height="25" VerticalContentAlignment="Center"  Grid.ColumnSpan="3" Margin="140,9,0,0" Width="261" /-->
            <TextBox x:Name="Param_EXE" TextWrapping="NoWrap" Text="-RTX" Grid.Row="1" Grid.Column="0" Height="25" VerticalContentAlignment="Center" Grid.ColumnSpan="3" Margin="140,9,0,0" Width="261">
                <TextBox.Resources>
                    <VisualBrush x:Key="HintText" TileMode="None" Opacity="1" Stretch="None" AlignmentX="Left" AlignmentY="Center">
                        <VisualBrush.Visual>
                            <TextBlock Text="0 is ok" Foreground="Gray" />
                        </VisualBrush.Visual>
                    </VisualBrush>
                </TextBox.Resources>
                <TextBox.Style>
                    <Style TargetType="{x:Type TextBox}">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="{x:Type TextBox}">
                                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                                        <Grid>
                                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center" />
                                            <TextBlock x:Name="Watermark" Text="Custom Launch Param is disabled" Foreground="Gray" Visibility="Collapsed" IsHitTestVisible="False" Opacity="0.5" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="3,0,0,0" />
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="Text" Value="">
                                            <Setter TargetName="Watermark" Property="Visibility" Value="Visible"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter Property="Background" Value="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
            </TextBox>
            
        </Grid>
    </DockPanel>

    <Window.Resources>
        <LinearGradientBrush x:Key="GradientBackground" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#FFD2E3FE" Offset="1" />
            <GradientStop Color="White" Offset="0" />
        </LinearGradientBrush>
    </Window.Resources>
</Window>
