<Window x:Class="ww_unlockfps.Advancelaunch"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ww_unlockfps"
        mc:Ignorable="d"
        Title="Manual Mode" Height="200" Width="330" ResizeMode="NoResize">
    <DockPanel Background="{DynamicResource GradientBackground}">
        <!--Grid DockPanel.Dock="Bottom">
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Label Content="Waiting Game launch" Grid.Row="1" Grid.ColumnSpan="2" HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Meiryo" FontSize="20" Foreground="#FF3A86FF"/>
            <Label x:Name="tiplaunch" Content="..." Grid.Row="2" Grid.ColumnSpan="2" HorizontalAlignment="Center" VerticalAlignment="Bottom" FontFamily="Meiryo" FontSize="20" Foreground="#FF3A86FF"/>
        </Grid-->
        <Grid HorizontalAlignment="Center" Height="100" VerticalAlignment="Top" DockPanel.Dock="Top">
            <Grid.Resources>
                <Style x:Key="rec" TargetType="Rectangle">
                    <Setter Property="Width" Value="10"/>
                    <Setter Property="Height" Value="30"/>
                    <Setter Property="Fill" Value="#FF72A8FF"/>
                </Style>
                <PowerEase x:Key="powerEase" Power="3" EasingMode="EaseInOut"/>
            </Grid.Resources>
            <Grid.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard RepeatBehavior="Forever" Storyboard.TargetProperty="Height">
                            <DoubleAnimation Storyboard.TargetName="rec1" To="56" BeginTime="0:0:0.0" Duration="0:0:0.5" EasingFunction="{StaticResource powerEase}" AutoReverse="True"/>
                            <DoubleAnimation Storyboard.TargetName="rec2" To="56" BeginTime="0:0:0.2" Duration="0:0:0.5" EasingFunction="{StaticResource powerEase}" AutoReverse="True"/>
                            <DoubleAnimation Storyboard.TargetName="rec3" To="56" BeginTime="0:0:0.4" Duration="0:0:0.5" EasingFunction="{StaticResource powerEase}" AutoReverse="True"/>
                            <DoubleAnimation Storyboard.TargetName="rec4" To="56" BeginTime="0:0:0.6" Duration="0:0:0.5" EasingFunction="{StaticResource powerEase}" AutoReverse="True"/>
                            <DoubleAnimation Storyboard.TargetName="rec5" To="56" BeginTime="0:0:0.8" Duration="0:0:0.5" EasingFunction="{StaticResource powerEase}" AutoReverse="True"/>
                            <DoubleAnimation Storyboard.TargetName="rec6" To="56" BeginTime="0:0:1.0" Duration="0:0:0.5" EasingFunction="{StaticResource powerEase}" AutoReverse="True"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Grid.Triggers>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="15"/>
            </Grid.ColumnDefinitions>
            <!--Label Content="Loading"
           FontSize="18"
           FontFamily="Times New Roman"
           Foreground="#252c41"
           FontWeight="Bold"
           Grid.ColumnSpan="6"
           VerticalContentAlignment="Center"
           HorizontalContentAlignment="Center"
           Margin="0,80,0,0"/-->
            <Rectangle Name="rec1" Grid.Column="0" Style="{StaticResource rec}"/>
            <Rectangle Name="rec2" Grid.Column="1" Style="{StaticResource rec}"/>
            <Rectangle Name="rec3" Grid.Column="2" Style="{StaticResource rec}"/>
            <Rectangle Name="rec4" Grid.Column="3" Style="{StaticResource rec}"/>
            <Rectangle Name="rec5" Grid.Column="4" Style="{StaticResource rec}"/>
            <Rectangle Name="rec6" Grid.Column="5" Style="{StaticResource rec}"/>
        </Grid>
        
        <!--StackPanel>
            <Label x:Name="tiplaunch" Content="Waiting for game to launch" Grid.Row="2" Grid.ColumnSpan="2" HorizontalAlignment="Center" VerticalAlignment="Top" FontFamily="Meiryo" FontSize="15" Foreground="#FF3A86FF" Margin="0,-15,0,0"/>
            <Label Content="填充" Grid.Row="2" Grid.ColumnSpan="2" HorizontalAlignment="Center" FontFamily="Meiryo" FontSize="15" Foreground="#f1404b" Height="*"  />
            <Label Content="tips" Grid.Row="2" Grid.ColumnSpan="2" HorizontalAlignment="Center" FontFamily="Meiryo" FontSize="15" Foreground="#f1404b" Height="29"  />
        </StackPanel-->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition Height="Auto"/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <Label x:Name="tiplaunch" Content="Waiting for game to launch" Grid.Row="0" HorizontalAlignment="Center"  FontFamily="Meiryo" FontSize="15" Foreground="#FF3A86FF" VerticalAlignment="Top" Margin="0,-15,0,0" />
            <TextBlock Text="Tips" Grid.Row="2" HorizontalAlignment="Center" FontFamily="Meiryo" FontSize="15" Foreground="#f1404b" VerticalAlignment="Bottom" Margin="0,0,0,5" >
                <TextBlock.TextDecorations>
                    <TextDecoration Location="Underline"/>
                </TextBlock.TextDecorations>
                <TextBlock.ToolTip>
                    <ToolTip>
                        <TextBlock 
            TextWrapping="Wrap" 
            MaxWidth="300"
            Text="In this mode, only the following functions are valid: Unlock FPS; Game Area Selection; Power Saving and Game Process Priority"/>
                    </ToolTip>
                </TextBlock.ToolTip>
            </TextBlock>

        </Grid>

    </DockPanel>
    <Window.Resources>
        <LinearGradientBrush x:Key="GradientBackground" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#FFD2E3FE" Offset="1" />
            <GradientStop Color="White" Offset="0" />
        </LinearGradientBrush>
    </Window.Resources>
</Window>
