<Window x:Class="ww_unlockfps.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ww_unlockfps"
        mc:Ignorable="d"
        xmlns:xctk="clr-namespace:Xceed.Wpf.Toolkit;assembly=Xceed.Wpf.Toolkit"
        Title="Wuther FPS Unlocker" Height="335" Width="350" ResizeMode="CanMinimize" WindowStartupLocation="CenterScreen">

    <DockPanel Background="{DynamicResource GradientBackground}">
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_Options" Height="23">
                <MenuItem Header="_Setup" Click="Setup_Click" ToolTip="Set game EXE path"/>
                <MenuItem Header="_Manual Mode" Click="Advance_Launch"/>
                <MenuItem x:Name="check_auto_start" Header="_Auto Start" IsCheckable="True" Checked="AutoStart_Checked" Unchecked="AutoStart_Unchecked" ToolTip="Quick launch to skip GUI"/>
                <MenuItem x:Name="check_power_saving" Header="_Power Saving" IsCheckable="True" ToolTip="Auto set FPS to 15 and low process priority upon game losing focus" Checked="Power_Saving_Checked" Unchecked="Power_Saving_Unchecked"/>
                <MenuItem x:Name="check_clearcache" Header="_Clear Cache" Click="ClearCache_Click" ToolTip="Reset Advanced Features Cache"/>
                <MenuItem x:Name="check_game_process_priority" Header="_Game Process Priority">
                    <MenuItem x:Name="ck_realtime" Header="_Realtime" IsCheckable="True" Click="Priority_Click"/>
                    <MenuItem x:Name="ck_high" Header="_High" IsCheckable="True" Click="Priority_Click"/>
                    <MenuItem x:Name="ck_above_normal" Header="_Above Normal" IsCheckable="True" Click="Priority_Click"/>
                    <MenuItem x:Name="ck_normal" Header="_Normal" IsCheckable="True" Click="Priority_Click"/>
                    <MenuItem x:Name="ck_below_normal" Header="_Below Normal" IsCheckable="True" Click="Priority_Click"/>
                    <MenuItem x:Name="ck_low" Header="_Low" IsCheckable="True" Click="Priority_Click"/>
                    <MenuItem x:Name="ck_default" Header="_Default" IsCheckable="True" Click="Priority_Click"/>
                </MenuItem>
                <MenuItem Header="_About" Click="About_Click"/>
                <Separator />
                <MenuItem Header="_Exit" Click="Exit_Main"/>
            </MenuItem>
        </Menu>


        <!-- 1. 将 Orientation 改为 Vertical (垂直排列) -->
        <!-- 2. 保持 HorizontalAlignment="Center"，这样内部所有元素都会居中 -->
        <StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,5,0,0">

            <!-- 第一行：FPS文字和输入框 -->
            <!-- 使用嵌套的StackPanel让它们在同一行 -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                <!-- 底部加点间距 -->
                <TextBlock Text="FPS:" Width="32"
                   VerticalAlignment="Center" 
                   FontSize="14"
                   Margin="0,0,10,0"/>

                <xctk:IntegerUpDown x:Name="Tb_main"
                            Minimum="0" 
                            Maximum="420" 
                            FontSize="13"           
                            PreviewKeyDown="TextBox_PreviewKeyDown"
                            PreviewTextInput="TextBox_PreviewTextInput"   
                            ValueChanged="Tb_main_ValueChanged"
                            Increment="1" 
                            ShowButtonSpinner="True" 
                            FormatString="N0" 
                            Width="260" 
                            Height="28" 
                            TextAlignment="Left"/>
            </StackPanel>

            <!-- 第二行：滑块控件 (自动位于正下方并居中) -->
            <Slider Style="{DynamicResource SliderStyle1}" 
            x:Name="sli_main"
            Width="280" 
            ValueChanged="Slider_ValueChanged_Main"
            Maximum="420" 
            Minimum="0"  
            TickPlacement="None" 
            TickFrequency="1" 
            IsSnapToTickEnabled="True" 
            SelectionEnd="{Binding RelativeSource={RelativeSource Self},Path=Value}" 
            IsSelectionRangeEnabled="True" 
            VerticalAlignment="Center"/>











            <StackPanel Orientation="Horizontal" Margin="0,20,0,15">
                <!-- 底部加点间距 -->
                <TextBlock Text="FOV:" Width="32"
                   VerticalAlignment="Center" 
                   FontSize="14"
                   Margin="0,0,10,0"/>

                <xctk:DoubleUpDown
                            x:Name="Tb_fov"
                            Minimum="15" 
                            Maximum="165" 
                            FontSize="13"           
                            ValueChanged="Tb_fov_ValueChanged"
                            Increment="0.1" 
                            ShowButtonSpinner="True" 
                            FormatString="F1"
                            Width="260" 
                            Height="28" 
                            TextAlignment="Left"/>
            </StackPanel>

            <Slider Style="{DynamicResource SliderStyle1}" 
                x:Name="sli_fov"
                Width="280" 
                Maximum="165" 
                Minimum="15"  
                Value="45"
                ValueChanged="Slider_ValueChanged_fov"
                TickPlacement="None" 
                TickFrequency="0.1" 
                IsSnapToTickEnabled="False" 
                SelectionEnd="{Binding RelativeSource={RelativeSource Self},Path=Value}" 
                IsSelectionRangeEnabled="True" 
                VerticalAlignment="Center"/>






            <!-- 使用 Grid 替代 StackPanel -->
            <Grid Margin="0,15,0,0">

                <!-- 左边的 CheckBox：默认靠左 -->
                <CheckBox 
                  x:Name="cb_advanced"
                  Content="Advanced Features (Beta)" Foreground="RoyalBlue"
                  VerticalContentAlignment="Center" 
                  FontSize="13"
                  VerticalAlignment="Center"
                  HorizontalAlignment="Left">

                    <CheckBox.ToolTip>
                        <ToolTip Content="Enable before starting the game, otherwise it won’t work"/>
                    </CheckBox.ToolTip>
                </CheckBox>
            </Grid>

            <!-- 使用 Grid 替代 StackPanel -->
            <Grid Margin="0,15,0,0">

                <!-- 左边的 CheckBox：默认靠左 -->
                <CheckBox 
                  x:Name="check_fov"
                  IsEnabled="{Binding IsChecked, ElementName=cb_advanced}"
                  Content="Enable FOV ADJ" 
                  VerticalContentAlignment="Center" Foreground="RoyalBlue"
                  FontSize="13"
                  VerticalAlignment="Center"
                  HorizontalAlignment="Left">

                    <CheckBox.ToolTip>
                        <ToolTip Content="N/A"/>
                    </CheckBox.ToolTip>
                </CheckBox>

                <CheckBox          
                  x:Name="check_hideuid"
                  IsEnabled="{Binding IsChecked, ElementName=cb_advanced}"
                  Content="Hide UID" Foreground="RoyalBlue"
                  VerticalContentAlignment="Center" Margin="135,0,0,0"
                  FontSize="13"
                  VerticalAlignment="Center"
                  HorizontalAlignment="Left">
                    <CheckBox.ToolTip>
                        <ToolTip Content="N/A"/>
                    </CheckBox.ToolTip>
                </CheckBox>

            </Grid>


            <!-- 使用 Grid 替代 StackPanel -->
            <Grid Margin="0,12,0,0">

                <!-- 左边的 CheckBox：默认靠左 -->
                <CheckBox x:Name="check_dx11" 
              Content="Use DX11 To Start Game" 
              VerticalContentAlignment="Center" 
              FontSize="13"
              VerticalAlignment="Center"
              HorizontalAlignment="Left">

                    <CheckBox.ToolTip>
                        <ToolTip Content="Try DirectX 11 to launch Game"/>
                    </CheckBox.ToolTip>
                </CheckBox>

                <!-- 右边的 Button：手动设置为靠右 -->
                <Button x:Name="start_but" 
                Content="Start Game" 
                Width="80" 
                Height="25"
                HorizontalAlignment="Right"
                VerticalAlignment="Center" Click="Start_Game"/>

            </Grid>


        </StackPanel>






    </DockPanel>

    <!-- 在资源字典中定义渐变背景 -->
    <Window.Resources>
        <LinearGradientBrush x:Key="GradientBackground" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#FFD2E3FE" Offset="1" />
            <GradientStop Color="White" Offset="0" />
        </LinearGradientBrush>
    </Window.Resources>
</Window>
    
    
    
    

